  Purpose: Linux privilege escalation enumeration.
  Path: /root/Desktop/Tools/linpeas.sh

[Install Log]
/root/Desktop/Tools/install.log
  Purpose: Full installation log.

HELP
EOF

    chmod +x /usr/local/bin/tools-help
}

cleanup() {
    echo "[*] Cleaning up installer..."
    rm -f /root/Desktop/tools.sh
    rm -f ./tools.sh || true
}

main() {
    add_sublime_repo
    install_apt_tools
    install_go_tools
    install_gem_tools
    install_asnmap
    install_rustscan
    install_sploitscan
    install_meta_detector
    install_trevor_tools
    install_teamfiltration
    install_crosslinked
    install_dpat
    install_pcredz
    install_bloodhound_tools
    install_pivot_tools
    download_helpers
    create_tools_help
    updatedb || true
    cleanup

    echo ""
    echo "[+] Installation complete."
    echo "[+] Run tools-help anytime to view installed tools and purposes."
    echo "[+] Log saved to: $LOG_FILE"
}

main
