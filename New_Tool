#!/bin/bash

set -u
set -o pipefail

TOOLS_DIR="/root/Desktop/Tools"
LOG_FILE="$TOOLS_DIR/install.log"

mkdir -p "$TOOLS_DIR"
exec > >(tee -a "$LOG_FILE") 2>&1

export DEBIAN_FRONTEND=noninteractive
export GOPATH="/root/go"
export PATH="$PATH:/root/go/bin"

echo "[*] Starting dropbox Kali tool installation..."
echo "[*] Tools directory: $TOOLS_DIR"
echo "[*] Log file: $LOG_FILE"

run_step() {
    local name="$1"
    shift

    echo ""
    echo "=================================================="
    echo "[*] Starting: $name"
    echo "=================================================="

    if "$@"; then
        echo "[+] Completed: $name"
    else
        echo "[!] Failed: $name"
        echo "[!] Continuing install. Check log: $LOG_FILE"
    fi
}

