add_sublime_repo() {
    wget -qO - https://download.sublimetext.com/sublimehq-pub.gpg \
        | gpg --dearmor \
        | tee /etc/apt/trusted.gpg.d/sublimehq-archive.gpg > /dev/null

    echo "deb https://download.sublimetext.com/ apt/stable/" \
        | tee /etc/apt/sources.list.d/sublime-text.list

    apt-get update -y
}

install_apt_tools() {
    apt-get update -y

    apt-get install -y \
        golang \
        remmina \
        seclists \
        netexec \
        gobuster \
        rlwrap \
        sublime-text \
        ffuf \
        amass \
        feroxbuster \
        proxychains4 \
        socat \
        jq \
        tmux \
        python3-pip \
        python3-venv \
        python3-impacket \
        impacket-scripts \
        ruby-full \
        unzip \
        git \
        wget \
        curl \
        make \
        gcc \
        nmap \
        libxml2-dev \
        libxslt1-dev \
        zlib1g-dev \
        libffi-dev \
        libssl-dev \
        build-essential
}

upgrade_system() {
    apt-get upgrade -y
}

install_go_tools() {
    mkdir -p "$GOPATH"

    go install -v github.com/projectdiscovery/subfinder/v2/cmd/subfinder@latest

    grep -qxF 'export GOPATH="/root/go"' /root/.bashrc || echo 'export GOPATH="/root/go"' >> /root/.bashrc
    grep -qxF 'export PATH="$PATH:/root/go/bin"' /root/.bashrc || echo 'export PATH="$PATH:/root/go/bin"' >> /root/.bashrc

    ln -sf /root/go/bin/subfinder /usr/local/bin/subfinder
}

install_gem_tools() {
    gem install haiti-hash
}

install_asnmap() {
    cd "$TOOLS_DIR"

    rm -f asnmap_1.1.0_linux_amd64.zip
    wget -q https://github.com/projectdiscovery/asnmap/releases/download/v1.1.0/asnmap_1.1.0_linux_amd64.zip

    unzip -o asnmap_1.1.0_linux_amd64.zip -d "$TOOLS_DIR"
    chmod +x "$TOOLS_DIR/asnmap"
    mv -f "$TOOLS_DIR/asnmap" /usr/local/bin/asnmap

    rm -f asnmap_1.1.0_linux_amd64.zip LICENSE README.md
}

install_rustscan() {
    cd "$TOOLS_DIR"

    rm -f rustscan_2.2.3_amd64.deb
    wget -q https://github.com/RustScan/RustScan/releases/download/2.2.3/rustscan_2.2.3_amd64.deb

    dpkg -i rustscan_2.2.3_amd64.deb || apt-get install -f -y
    rm -f rustscan_2.2.3_amd64.deb
}

install_sploitscan() {
    cd "$TOOLS_DIR"

    if [ ! -d "$TOOLS_DIR/SploitScan" ]; then
        git clone https://github.com/xaitax/SploitScan.git "$TOOLS_DIR/SploitScan"
    fi

    cd "$TOOLS_DIR/SploitScan"
    rm -rf venv
    python3 -m venv venv
    source venv/bin/activate
    pip install --upgrade pip setuptools wheel
    pip install -r requirements.txt
    deactivate

    chmod +x sploitscan.py

    cat > /usr/local/bin/sploitscan << 'EOF'
#!/bin/bash
cd /root/Desktop/Tools/SploitScan
source venv/bin/activate
python3 sploitscan.py "$@"
EOF

    chmod +x /usr/local/bin/sploitscan
}

install_meta_detector() {
    cd "$TOOLS_DIR"

    if [ ! -d "$TOOLS_DIR/Meta-Detector" ]; then
        git clone https://github.com/stolenusername/Meta-Detector.git "$TOOLS_DIR/Meta-Detector"
    fi

    cd "$TOOLS_DIR/Meta-Detector"
    go build meta-detector.go
    chmod +x meta-detector
    ./meta-detector -download || true
}

install_trevor_tools() {
    rm -rf "$TOOLS_DIR/trevor-venv"
    python3 -m venv "$TOOLS_DIR/trevor-venv"

    source "$TOOLS_DIR/trevor-venv/bin/activate"
    pip install --upgrade pip setuptools wheel
    pip install git+https://github.com/blacklanternsecurity/trevorproxy
    pip install git+https://github.com/blacklanternsecurity/trevorspray
    deactivate

    cat > /usr/local/bin/trevorproxy << 'EOF'
#!/bin/bash
/root/Desktop/Tools/trevor-venv/bin/trevorproxy "$@"
EOF

    cat > /usr/local/bin/trevorspray << 'EOF'
#!/bin/bash
/root/Desktop/Tools/trevor-venv/bin/trevorspray "$@"
EOF

    chmod +x /usr/local/bin/trevorproxy /usr/local/bin/trevorspray
}

install_teamfiltration() {
    cd "$TOOLS_DIR"

    rm -f TeamFiltration-v3.5.4-linux-x86_64.zip
    wget -q https://github.com/Flangvik/TeamFiltration/releases/download/v3.5.4/TeamFiltration-v3.5.4-linux-x86_64.zip

    unzip -o TeamFiltration-v3.5.4-linux-x86_64.zip -d "$TOOLS_DIR"
    mkdir -p "$TOOLS_DIR/Spray"

    mv -f "$TOOLS_DIR/TeamFiltration" "$TOOLS_DIR/Spray/" 2>/dev/null || true
    mv -f "$TOOLS_DIR/TeamFiltrationConfig_Example.json" "$TOOLS_DIR/Spray/" 2>/dev/null || true

    chmod +x "$TOOLS_DIR/Spray/TeamFiltration" 2>/dev/null || true
    rm -f TeamFiltration-v3.5.4-linux-x86_64.zip
}

install_crosslinked() {
    cd "$TOOLS_DIR"

    if [ ! -d "$TOOLS_DIR/crosslinked" ]; then
        git clone https://github.com/m8sec/crosslinked "$TOOLS_DIR/crosslinked"
    fi

    cd "$TOOLS_DIR/crosslinked"
    rm -rf venv
    python3 -m venv venv

    source venv/bin/activate
    pip install --upgrade pip setuptools wheel
    pip install .
    deactivate

    cat > /usr/local/bin/crosslinked << 'EOF'
#!/bin/bash
/root/Desktop/Tools/crosslinked/venv/bin/crosslinked "$@"
EOF

    chmod +x /usr/local/bin/crosslinked
}

install_dpat() {
    cd "$TOOLS_DIR"

    if [ ! -d "$TOOLS_DIR/DPAT" ]; then
        git clone https://github.com/clr2of8/DPAT.git "$TOOLS_DIR/DPAT"
    fi

    cd "$TOOLS_DIR/DPAT"
    rm -rf venv
    python3 -m venv venv

    source venv/bin/activate
    pip install --upgrade pip setuptools wheel
    pip install -r requirements.txt
    deactivate
}

install_pcredz() {
    cd "$TOOLS_DIR"

    if [ ! -d "$TOOLS_DIR/PCredz" ]; then
        git clone https://github.com/lgandx/PCredz.git "$TOOLS_DIR/PCredz"
    fi

    cat > /usr/local/bin/pcredz << 'EOF'
#!/bin/bash
python3 /root/Desktop/Tools/PCredz/Pcredz "$@"
EOF

    chmod +x /usr/local/bin/pcredz
}

install_bloodhound_tools() {
    apt-get install -y bloodhound bloodhound.py || true

    rm -rf "$TOOLS_DIR/bloodhound-venv"
    python3 -m venv "$TOOLS_DIR/bloodhound-venv"

    source "$TOOLS_DIR/bloodhound-venv/bin/activate"
    pip install --upgrade pip setuptools wheel
    pip install bloodhound bloodhound-ce || true
    deactivate

    cat > /usr/local/bin/bloodhound-python-venv << 'EOF'
#!/bin/bash
/root/Desktop/Tools/bloodhound-venv/bin/bloodhound-python "$@"
EOF

    chmod +x /usr/local/bin/bloodhound-python-venv
}

install_pivot_tools() {
    cd "$TOOLS_DIR"

    CHISEL_VERSION="1.9.1"
    rm -f "chisel_${CHISEL_VERSION}_linux_amd64.gz" "chisel_${CHISEL_VERSION}_linux_amd64"

    wget -q "https://github.com/jpillora/chisel/releases/download/v${CHISEL_VERSION}/chisel_${CHISEL_VERSION}_linux_amd64.gz"
    gunzip -f "chisel_${CHISEL_VERSION}_linux_amd64.gz"
    chmod +x "chisel_${CHISEL_VERSION}_linux_amd64"
    mv -f "chisel_${CHISEL_VERSION}_linux_amd64" /usr/local/bin/chisel

    LIGOLO_VERSION="0.7.5"
    rm -f ligolo-ng_*_linux_amd64.tar.gz

    wget -q "https://github.com/nicocha30/ligolo-ng/releases/download/v${LIGOLO_VERSION}/ligolo-ng_proxy_${LIGOLO_VERSION}_linux_amd64.tar.gz"
    wget -q "https://github.com/nicocha30/ligolo-ng/releases/download/v${LIGOLO_VERSION}/ligolo-ng_agent_${LIGOLO_VERSION}_linux_amd64.tar.gz"

    mkdir -p "$TOOLS_DIR/ligolo-ng/proxy" "$TOOLS_DIR/ligolo-ng/agent"

    tar -xzf "ligolo-ng_proxy_${LIGOLO_VERSION}_linux_amd64.tar.gz" -C "$TOOLS_DIR/ligolo-ng/proxy"
    tar -xzf "ligolo-ng_agent_${LIGOLO_VERSION}_linux_amd64.tar.gz" -C "$TOOLS_DIR/ligolo-ng/agent"

    chmod +x "$TOOLS_DIR/ligolo-ng/proxy/proxy" 2>/dev/null || true
    chmod +x "$TOOLS_DIR/ligolo-ng/agent/agent" 2>/dev/null || true

    ln -sf "$TOOLS_DIR/ligolo-ng/proxy/proxy" /usr/local/bin/ligolo-proxy
    ln -sf "$TOOLS_DIR/ligolo-ng/agent/agent" /usr/local/bin/ligolo-agent

    rm -f ligolo-ng_*_linux_amd64.tar.gz
}

download_helpers() {
    wget -q https://github.com/carlospolop/PEASS-ng/releases/latest/download/linpeas.sh -O "$TOOLS_DIR/linpeas.sh"
    chmod +x "$TOOLS_DIR/linpeas.sh"

    wget -q https://gist.githubusercontent.com/jhaddix/86a06c5dc309d08580a018c66354a056/raw/96f4e51d96b2203f19f6381c8c545b278eaa0837/all.txt -O "$TOOLS_DIR/subdomains.txt"
}

verification_summary() {
    echo ""
    echo "=================================================="
    echo "[*] Verification Summary"
    echo "=================================================="

    for cmd in \
        subl \
        remmina \
        netexec \
        gobuster \
        ffuf \
        feroxbuster \
        amass \
        subfinder \
        asnmap \
        rustscan \
        sploitscan \
        crosslinked \
        pcredz \
        haiti \
        chisel \
        ligolo-proxy \
        ligolo-agent \
        proxychains4 \
        socat \
        tools-help
    do
        if command -v "$cmd" >/dev/null 2>&1; then
            echo "[+] $cmd found: $(command -v "$cmd")"
        else
            echo "[!] $cmd not found"
        fi
    done
}

cleanup() {
    rm -f /root/Desktop/tools.sh
    rm -f ./tools.sh 2>/dev/null || true
}

main() {
    run_step "Create tools-help command" create_tools_help
    run_step "Add Sublime Text repository" add_sublime_repo
    run_step "Install apt tools and dependencies" install_apt_tools
    run_step "Upgrade system" upgrade_system
    run_step "Install Go tools" install_go_tools
    run_step "Install Ruby gem tools" install_gem_tools
    run_step "Install asnmap" install_asnmap
    run_step "Install RustScan" install_rustscan
    run_step "Install SploitScan" install_sploitscan
    run_step "Install Meta-Detector" install_meta_detector
    run_step "Install TrevorProxy and TrevorSpray" install_trevor_tools
    run_step "Install TeamFiltration" install_teamfiltration
    run_step "Install CrossLinked" install_crosslinked
    run_step "Install DPAT" install_dpat
    run_step "Install Pcredz" install_pcredz
    run_step "Install BloodHound tools" install_bloodhound_tools
    run_step "Install pivot tools" install_pivot_tools
    run_step "Download helper scripts and lists" download_helpers
    run_step "Update locate database" updatedb
    run_step "Verification summary" verification_summary
    run_step "Cleanup installer" cleanup

    echo ""
    echo "[+] Installation script completed."
    echo "[+] Run this anytime:"
    echo "    tools-help"
    echo ""
    echo "[+] Install log:"
    echo "    $LOG_FILE"
}

main
